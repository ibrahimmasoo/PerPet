{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["name", "email"]
    },
    "Pet": {
      "title": "Pet",
      "description": "Information about a pet available for adoption",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Pet name" },
        "type": { "type": "string", "enum": ["cat", "dog"], "description": "Type of pet" },
        "age": { "type": "number", "description": "Age in years" },
        "description": { "type": "string", "description": "Detailed description" },
        "image": { "type": "string", "format": "uri", "description": "URL to pet image" },
        "owner_id": { "type": "string", "description": "UID of the user who listed the pet" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "type", "age", "description", "image", "owner_id"]
    },
    "AdoptionRequest": {
      "title": "AdoptionRequest",
      "description": "A request from a user to adopt a specific pet",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "UID of the requester" },
        "pet_id": { "type": "string", "description": "ID of the pet" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"], "description": "Current status of the request" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["user_id", "pet_id", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/pets/{petId}": {
      "schema": "Pet",
      "description": "Pet listings"
    },
    "/adoption_requests/{requestId}": {
      "schema": "AdoptionRequest",
      "description": "Adoption requests"
    }
  }
}
